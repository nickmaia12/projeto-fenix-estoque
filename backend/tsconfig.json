{
  "compilerOptions": {
    /* Configurações de Ambiente */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],

    /* Caminhos do Projeto */
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "./",

    /* Interoperabilidade e Segurança */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,

    /* Outras Opções */
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}